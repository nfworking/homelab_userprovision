@model List<ADPortal.Models.AdOU>
@{
    ViewData["Title"] = "Organisational Units";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1 fw-semibold">Organisational Units</h1>
        <p class="text-muted mb-0">@Model.Count OU(s) found in corp.lurking.site</p>
    </div>
    <a href="/OUs/Tree" class="btn btn-outline-primary">
        <i class="bi bi-tree me-1"></i>Tree View
    </a>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>@ViewBag.Error</div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Distinguished Name</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ou in Model)
                        {
                            <tr>
                                <td>
                                    <i class="bi bi-folder me-2 text-warning"></i>
                                    <span class="fw-medium">@ou.Name</span>
                                </td>
                                <td>
                                    <code class="small text-muted">@ou.DistinguishedName</code>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-diagram-3 fs-1 d-block mb-3"></i>
                No OUs found.
            </div>
        }
    </div>
</div>
