@model ADPortal.Models.AdUser
@{
    ViewData["Title"] = Model.DisplayName ?? Model.SamAccountName;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a href="/Users">Users</a></li>
                <li class="breadcrumb-item active">@Model.SamAccountName</li>
            </ol>
        </nav>
        <h1 class="h3 mb-0 fw-semibold">@(Model.DisplayName ?? Model.SamAccountName)</h1>
    </div>
    <div class="d-flex gap-2">
        <a href="/Users/ResetPassword/@Model.SamAccountName" class="btn btn-warning">
            <i class="bi bi-key me-1"></i>Reset Password
        </a>
        <a href="/Users" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-3">
    <!-- Profile details -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-transparent fw-semibold border-bottom">
                <i class="bi bi-person me-2 text-primary"></i>Account Information
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="text-muted small">First Name</label>
                        <div>@(Model.GivenName ?? "—")</div>
                    </div>
                    <div class="col-sm-6">
                        <label class="text-muted small">Last Name</label>
                        <div>@(Model.Surname ?? "—")</div>
                    </div>
                    <div class="col-sm-6">
                        <label class="text-muted small">Display Name</label>
                        <div>@(Model.DisplayName ?? "—")</div>
                    </div>
                    <div class="col-sm-6">
                        <label class="text-muted small">Username (SAM)</label>
                        <div><code>@Model.SamAccountName</code></div>
                    </div>
                    <div class="col-sm-6">
                        <label class="text-muted small">Email</label>
                        <div>@(Model.Email ?? "—")</div>
                    </div>
                    <div class="col-sm-6">
                        <label class="text-muted small">Department</label>
                        <div>@(Model.Department ?? "—")</div>
                    </div>
                    <div class="col-sm-6">
                        <label class="text-muted small">Job Title</label>
                        <div>@(Model.Title ?? "—")</div>
                    </div>
                    <div class="col-sm-6">
                        <label class="text-muted small">Account Status</label>
                        <div>
                            @if (Model.IsEnabled)
                            {
                                <span class="badge bg-success">Enabled</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Disabled</span>
                            }
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="text-muted small">Distinguished Name</label>
                        <div><code class="small text-break">@Model.DistinguishedName</code></div>
                    </div>
                    <div class="col-12">
                        <label class="text-muted small">OU Path</label>
                        <div class="small text-muted">@(Model.OuPath ?? "—")</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Logon info -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent fw-semibold border-bottom">
                <i class="bi bi-clock me-2 text-primary"></i>Logon Information
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="text-muted small">Last Logon</label>
                        <div>@(Model.LastLogon.HasValue ? Model.LastLogon.Value.ToString("dd MMM yyyy HH:mm") : "Never / Unknown")</div>
                    </div>
                    <div class="col-sm-6">
                        <label class="text-muted small">Password Last Set</label>
                        <div>@(Model.PasswordLastSet.HasValue ? Model.PasswordLastSet.Value.ToString("dd MMM yyyy HH:mm") : "Never")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Group memberships -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent fw-semibold border-bottom">
                <i class="bi bi-diagram-2 me-2 text-primary"></i>Group Memberships
                <span class="badge bg-secondary ms-1">@Model.MemberOf.Count</span>
            </div>
            <div class="card-body p-0">
                @if (Model.MemberOf.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var group in Model.MemberOf.OrderBy(g => g))
                        {
                            <li class="list-group-item small py-2">
                                <i class="bi bi-people me-2 text-muted"></i>@group
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="p-3 text-muted small text-center">No group memberships found.</div>
                }
            </div>
        </div>
    </div>
</div>
