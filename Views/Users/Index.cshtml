@model List<ADPortal.Models.AdUser>
@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1 fw-semibold">Users</h1>
        <p class="text-muted mb-0">@Model.Count user(s) found</p>
    </div>
    <a href="/Users/Create" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i>Create User
    </a>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>@ViewBag.Error</div>
}

<!-- Search bar -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="get" action="/Users" class="d-flex gap-2">
            <input type="text" name="search" value="@ViewBag.Search"
                   class="form-control" placeholder="Search by name, username, email or department..." />
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-search me-1"></i>Search
            </button>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
            {
                <a href="/Users" class="btn btn-outline-secondary">Clear</a>
            }
        </form>
    </div>
</div>

<!-- Users table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Username</th>
                            <th>Email</th>
                            <th>Department</th>
                            <th>OU</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-medium">@(string.IsNullOrEmpty(user.DisplayName) ? user.SamAccountName : user.DisplayName)</div>
                                    @if (!string.IsNullOrEmpty(user.Title))
                                    {
                                        <div class="text-muted small">@user.Title</div>
                                    }
                                </td>
                                <td class="text-muted">@user.SamAccountName</td>
                                <td class="text-muted small">@(user.Email ?? "—")</td>
                                <td class="text-muted small">@(user.Department ?? "—")</td>
                                <td>
                                    <span class="text-muted small ou-path" title="@user.OuPath">
                                        @(user.OuPath.Length > 40 ? user.OuPath[..40] + "…" : user.OuPath)
                                    </span>
                                </td>
                                <td>
                                    @if (user.IsEnabled)
                                    {
                                        <span class="badge bg-success">Enabled</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Disabled</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a href="/Users/Details/@user.SamAccountName"
                                           class="btn btn-sm btn-outline-primary" title="View details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a href="/Users/ResetPassword/@user.SamAccountName"
                                           class="btn btn-sm btn-outline-warning" title="Reset password">
                                            <i class="bi bi-key"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-person-x fs-1 d-block mb-3"></i>
                No users found@(ViewBag.Search != null ? $" matching \"{ViewBag.Search}\"" : "").
            </div>
        }
    </div>
</div>
