@model ADPortal.Models.DashboardStats
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1 fw-semibold">Dashboard</h1>
        <p class="text-muted mb-0">Active Directory overview &mdash; corp.lurking.site</p>
    </div>
    <span class="badge bg-success px-3 py-2">
        <i class="bi bi-circle-fill me-1" style="font-size:.6rem"></i>Connected
    </span>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle me-2"></i>@ViewBag.Error
    </div>
}
else if (Model != null)
{
    <!-- Stat cards -->
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-primary bg-opacity-10 text-primary rounded-3 p-3">
                        <i class="bi bi-people fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Total Users</div>
                        <div class="fs-3 fw-bold">@Model.TotalUsers</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-success bg-opacity-10 text-success rounded-3 p-3">
                        <i class="bi bi-person-check fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Enabled</div>
                        <div class="fs-3 fw-bold text-success">@Model.EnabledUsers</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-danger bg-opacity-10 text-danger rounded-3 p-3">
                        <i class="bi bi-person-x fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Disabled</div>
                        <div class="fs-3 fw-bold text-danger">@Model.DisabledUsers</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-warning bg-opacity-10 text-warning rounded-3 p-3">
                        <i class="bi bi-diagram-3 fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Org Units</div>
                        <div class="fs-3 fw-bold">@Model.TotalOUs</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick actions + recent users -->
    <div class="row g-3">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-transparent fw-semibold border-bottom">
                    <i class="bi bi-lightning me-2 text-primary"></i>Quick Actions
                </div>
                <div class="card-body d-grid gap-2">
                    <a href="/Users" class="btn btn-outline-primary text-start">
                        <i class="bi bi-search me-2"></i>Search Users
                    </a>
                    <a href="/OUs" class="btn btn-outline-secondary text-start">
                        <i class="bi bi-diagram-3 me-2"></i>Browse Org Units
                    </a>
                    <a href="/OUs/Tree" class="btn btn-outline-secondary text-start">
                        <i class="bi bi-tree me-2"></i>OU Tree View
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-transparent fw-semibold border-bottom">
                    <i class="bi bi-clock-history me-2 text-primary"></i>Recently Active Users
                </div>
                <div class="card-body p-0">
                    @if (Model.RecentUsers.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>User</th>
                                        <th>Department</th>
                                        <th>Last Logon</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var user in Model.RecentUsers)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-medium">@user.DisplayName</div>
                                                <div class="text-muted small">@user.SamAccountName</div>
                                            </td>
                                            <td class="text-muted small">@(user.Department ?? "—")</td>
                                            <td class="text-muted small">
                                                @(user.LastLogon.HasValue
                                                    ? user.LastLogon.Value.ToString("dd MMM yyyy")
                                                    : "Never")
                                            </td>
                                            <td>
                                                <a href="/Users/Details/@user.SamAccountName"
                                                   class="btn btn-sm btn-outline-primary">View</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="p-4 text-center text-muted">No recent logons found.</div>
                    }
                </div>
            </div>
        </div>
    </div>
}
